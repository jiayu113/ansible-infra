# =============================================
# MySQL 配置文件
# 由 Ansible 自动生成，请勿手动修改！
# 生成时间：{{ ansible_date_time.date }}
# 目标主机：{{ inventory_hostname }}
# 服务角色：{{ server_role }}
# =============================================

[client]
port            = {{ mysql_port }}
socket          = /var/run/mysqld/mysqld.sock
default-character-set = {{ mysql_character_set }}

[mysqld]
# ===== 基础配置 =====
user            = mysql
pid-file        = /var/run/mysqld/mysqld.pid
socket          = /var/run/mysqld/mysqld.sock
port            = {{ mysql_port }}
datadir         = {{ mysql_datadir }}
bind-address    = {{ mysql_bind_address }}

# ===== 字符集 =====
character-set-server  = {{ mysql_character_set }}
collation-server      = {{ mysql_collation }}

# ===== 连接配置 =====
max_connections       = {{ mysql_max_connections }}
max_connect_errors    = 10000
wait_timeout          = 600
interactive_timeout   = 600

# ===== 主从复制：服务器唯一ID =====
server-id             = {{ mysql_server_id }}

{% if server_role == 'master_db' %}
# =============================================
# 主库专属配置
# =============================================
# 开启二进制日志（主从复制必须）
log-bin               = mysql-bin
binlog_format         = {{ mysql_binlog_format }}
log-slave-updates     = 1
binlog_expire_logs_seconds = 604800   # binlog 保留7天

# 主库不设置只读
read_only             = 0

# 要同步的数据库（按需取消注释）
# binlog-do-db        = mydb

# 不同步的数据库
binlog-ignore-db      = mysql
binlog-ignore-db      = information_schema
binlog-ignore-db      = performance_schema

{% elif server_role == 'slave_db' %}
# =============================================
# 从库专属配置
# =============================================
# 从库设置只读（防止误写入）
read_only             = 1
super_read_only       = 1

# relay log 配置
relay_log             = relay-bin
relay_log_index       = relay-bin.index
log_slave_updates     = 1

# 开启二进制日志（从库也建议开，方便级联复制）
log-bin               = mysql-bin
binlog_format         = {{ mysql_binlog_format }}

# 从库跳过部分错误（按需开启）
# slave-skip-errors   = 1062

{% endif %}

# ===== 慢查询日志 =====
slow_query_log        = {{ mysql_slow_query_log }}
slow_query_log_file   = /var/log/mysql/slow.log
long_query_time       = {{ mysql_slow_query_time }}

# ===== InnoDB 配置 =====
innodb_buffer_pool_size       = {{ (ansible_memtotal_mb * 0.7) | int }}M
innodb_log_file_size          = 256M
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table         = 1

[mysqldump]
quick
quote-names
max_allowed_packet    = 64M

[mysql]
default-character-set = {{ mysql_character_set }}
