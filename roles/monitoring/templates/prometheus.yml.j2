# 由 Ansible 自动生成，请勿手动修改！
# 生成时间：{{ ansible_date_time.date }}

global:
  scrape_interval:     {{ prometheus_scrape_interval }}   # 每15秒抓一次
  evaluation_interval: {{ prometheus_evaluation_interval }}

# 告警规则文件（后续可扩展）
rule_files:
  # - /etc/prometheus/rules/*.yml

# ===== 抓取目标配置 =====
scrape_configs:

  # Prometheus 自身监控
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']
        labels:
          instance: 'prometheus-server'

  # ===== 所有服务器的 Node Exporter =====
  - job_name: 'node_exporter'
    static_configs:
{% for host in groups['all'] %}
{% if hostvars[host]['ansible_host'] is defined %}
      - targets: ['{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}']
        labels:
          instance: '{{ host }}'
          role: '{{ hostvars[host]['role'] | default('unknown') }}'
{% endif %}
{% endfor %}

